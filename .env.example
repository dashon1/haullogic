# HaulLogic Environment Variables
# Copy this file to .env.local and fill in your values

# Base44 App ID (required) — find in your Base44 project settings
VITE_BASE44_APP_ID=

# Stripe publishable key (required for payment features)
VITE_STRIPE_PUBLISHABLE_KEY=

# Optional: enable legacy Base44 SDK import paths
BASE44_LEGACY_SDK_IMPORTS=false
